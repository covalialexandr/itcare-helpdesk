# rezervate pentru a nu fi commitate niciodata.
# ============================================================
appsettings.Development.json
appsettings.Local.json
appsettings.*.local.json
secrets.json
*.env
.env.local
eve-credentials.json
anthropic-key.txt

# Permitem appsettings.json (cu connection string Trusted_Connection — nu e secret),
# dar daca cineva schimba sa adauge parola, sa-l mute in appsettings.Local.json.
