<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ITCareHelpdesk.App.ViewModels"
        xmlns:models="using:ITCareHelpdesk.App.Models"
        xmlns:controls="using:ITCareHelpdesk.App.Controls"
        x:Class="ITCareHelpdesk.App.Views.CreateTicketWindow"
        x:DataType="vm:CreateTicketViewModel"
        Title="Tichet nou — ITCare"
        Icon="avares://ITCareHelpdesk/Assets/itcare-logo.ico"
        Width="720" Height="780"
        MinWidth="640" MinHeight="700"
        WindowStartupLocation="CenterOwner"
        SystemDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border CornerRadius="16"
            Background="{DynamicResource BgDeep}"
            BorderBrush="{DynamicResource GlassBorderActive}"   
            BorderThickness="1"
            BoxShadow="0 32 80 0 #CC000000">

        <Grid RowDefinitions="Auto,*,Auto">

            <!-- Header cu titlu + close. Drag-handle peste tot top-ul. -->
            <Border Grid.Row="0" Padding="28,22,28,18"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="0,0,0,1"
                    PointerPressed="OnDragChromeAreaPressed">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="TICHET NOU" Classes="label" />
                        <TextBlock Text="Adauga un tichet" Classes="h2" />
                    </StackPanel>
                    <Button Grid.Column="1" Content="✕" Classes="ghost"
                            Width="34" Height="34" Padding="0"
                            VerticalAlignment="Top"
                            Click="OnCancelClick" />
                </Grid>
            </Border>

            <!-- Continut form -->
            <ScrollViewer Grid.Row="1" Padding="28,20"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="18">

                    <!-- Titlul tichetului — campul cel mai important; il facem singular si vizibil -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="TITLU" Classes="label" />
                        <TextBox Text="{Binding Titlu, Mode=TwoWay}"
                                 Watermark="Ex: Server ERP nu raspunde — useri blocati"
                                 FontSize="15" />
                        <TextBlock Text="Minim 6 caractere. Fii specific — un titlu bun economiseste 5 minute la triaj."
                                   Classes="muted" />
                    </StackPanel>

                    <!-- Descriere -->
                    <StackPanel Spacing="6">
                        <TextBlock Text="DESCRIERE" Classes="label" />
                        <TextBox Text="{Binding Descriere, Mode=TwoWay}"
                                 Watermark="Context, pasi de reproducere, ce ai incercat..."
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="120" />
                    </StackPanel>

                    <!-- Client + categorie -->
                    <Grid ColumnDefinitions="*,14,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="CLIENT" Classes="label" />
                            <ComboBox ItemsSource="{Binding ClientOptions}"
                                      SelectedItem="{Binding SelectedClient, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:Client">
                                        <TextBlock Text="{Binding NumeCompanie}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="CATEGORIE" Classes="label" />
                            <ComboBox ItemsSource="{Binding CategoryOptions}"
                                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="models:CategoryOption">
                                        <TextBlock Text="{Binding Display}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <!-- Prioritate + tip -->
                    <Grid ColumnDefinitions="*,14,*">
                        <StackPanel Grid.Column="0" Spacing="6">
                            <TextBlock Text="PRIORITATE" Classes="label" />
                            <ComboBox ItemsSource="{Binding Priorities}"
                                      SelectedItem="{Binding SelectedPriority, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="6">
                            <TextBlock Text="TIP" Classes="label" />
                            <ComboBox ItemsSource="{Binding Types}"
                                      SelectedItem="{Binding SelectedType, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch" />
                        </StackPanel>
                    </Grid>

                    <!-- AI suggest banner — apare doar daca AI este configurat (cheie API setata) -->
                    <Border Background="{DynamicResource BgSurface1}"
                            BorderBrush="{DynamicResource GlassBorderActive}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16,12"
                            IsVisible="{Binding AiEnabled}">
                        <Grid ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">
                            <!-- "AI" emblem in cyan -->
                            <Border Grid.Column="0"
                                    Width="36" Height="36" CornerRadius="18"
                                    Background="{DynamicResource AccentGradient}">
                                <TextBlock Text="AI"
                                           FontSize="11" FontWeight="Black"
                                           Foreground="#06070D"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0" Spacing="2">
                                <TextBlock Text="ASISTENT AI" Classes="label" />
                                <TextBlock Text="Lasa Claude sa propuna categoria si prioritatea pe baza titlului."
                                           FontSize="11" Foreground="{DynamicResource TextSecondary}" />
                                <TextBlock Text="{Binding AiSuggestion}"
                                           FontSize="11"
                                           Foreground="{DynamicResource Accent}"
                                           FontStyle="Italic"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"
                                           IsVisible="{Binding AiSuggestion, Converter={x:Static controls:Converters.StringNotEmpty}}" />
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Classes="primary"
                                    Content="✨ Sugereaza"
                                    Command="{Binding SuggestCommand}"
                                    Padding="14,10"
                                    FontSize="12" />
                        </Grid>
                    </Border>

                    <!-- Mesaj eroare. Foloseam un singur TextBlock fara wrap si erorile lungi
                         (ex: payload-ul JSON de la Anthropic API) ieseau in afara card-ului.
                         Acum: extragem un mesaj scurt user-friendly + pastram payload-ul brut in tooltip
                         pentru cazurile unde dezvoltatorul vrea detalii complete. -->
                    <Border Background="#1AFF3B5C"
                            BorderBrush="{DynamicResource StatusCritical}"
                            BorderThickness="1"
                            Padding="14,12"
                            CornerRadius="8"
                            HorizontalAlignment="Stretch"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static controls:Converters.StringNotEmpty}}"
                            ToolTip.Tip="{Binding ErrorMessage}">
                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Top">
                            <TextBlock Grid.Column="0"
                                       Text="⚠"
                                       FontSize="16"
                                       Foreground="{DynamicResource StatusCritical}"
                                       VerticalAlignment="Top"
                                       Margin="0,1,10,0" />
                            <!-- TextWrapping="Wrap" + MaxLines + TextTrimming ne da "Show first 3 lines, then ..."
                                 fara sa explodam dialog-ul daca API-ul intoarce un payload de 2KB -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding ErrorMessage}"
                                       Foreground="{DynamicResource StatusCritical}"
                                       FontSize="12"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </Border>

                    <!-- Notita despre tehnician asignat — momentan il lasam neasignat la creare.
                         Folosim GlassBorderActive ca sa fie consistent cu banner-ul AI de mai sus;
                         GlassBorder era prea slab si border-ul parea ca "lipseste". -->
                    <Border Background="{DynamicResource BgSurface1}"
                            BorderBrush="{DynamicResource GlassBorderActive}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="16,14"
                            HorizontalAlignment="Stretch">
                        <Grid ColumnDefinitions="Auto,*" VerticalAlignment="Center">
                            <!-- Iconita rotunda ca sa balanseze vizual cu banner-ul AI -->
                            <Border Grid.Column="0"
                                    Width="32" Height="32" CornerRadius="16"
                                    Background="{DynamicResource GlassFill}"
                                    BorderBrush="{DynamicResource GlassBorderActive}"
                                    BorderThickness="1">
                                <TextBlock Text="◷"
                                           FontSize="16"
                                           Foreground="{DynamicResource TextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" Margin="12,0,0,0" Spacing="3">
                                <TextBlock Text="ATRIBUIRE TEHNICIAN" Classes="label" />
                                <TextBlock Classes="body" FontSize="12" TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextSecondary}"
                                           Text="Tichetul se creeaza fara tehnician asignat — va fi preluat din coada de catre un L1/L2 disponibil. Asignarea manuala se face din pagina Tichete." />
                            </StackPanel>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- Footer cu actiuni -->
            <Border Grid.Row="2" Padding="28,18"
                    BorderBrush="{DynamicResource GlassBorder}"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Grid.Column="0" Classes="muted"
                               Text="Tichetul intra automat in coada cu SLA dupa prioritatea aleasa."
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1" Classes="ghost" Content="Anuleaza"
                            Padding="20,12" Click="OnCancelClick" />
                    <Button Grid.Column="2" Classes="primary" Content="↳  Creeaza tichet"
                            Command="{Binding SubmitCommand}"
                            IsDefault="True"
                            Margin="12,0,0,0"
                            Padding="22,12"
                            FontSize="14" />
                </Grid>
            </Border>

            <!-- Busy overlay -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Background="#CC06070D"
                    CornerRadius="16"
                    IsVisible="{Binding IsBusy}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14">
                    <Border Width="36" Height="36" CornerRadius="18"
                            Background="{DynamicResource Accent}">
                        <Border.Styles>
                            <Style Selector="Border">
                                <Style.Animations>
                                    <Animation Duration="0:0:1.2" IterationCount="INFINITE">
                                        <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                                        <KeyFrame Cue="50%"><Setter Property="Opacity" Value="1.0" /></KeyFrame>
                                        <KeyFrame Cue="100%"><Setter Property="Opacity" Value="0.25" /></KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Border.Styles>
                    </Border>
                    <TextBlock Text="{Binding BusyMessage}" Classes="body" HorizontalAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
