<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ITCareHelpdesk.App.ViewModels"
             xmlns:models="using:ITCareHelpdesk.App.Models"
             xmlns:controls="using:ITCareHelpdesk.App.Controls"
             x:Class="ITCareHelpdesk.App.Views.TechniciansView"
             x:DataType="vm:TechniciansViewModel">

    <Grid RowDefinitions="Auto,*" Margin="32,28,32,32">

        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,18">
            <StackPanel Grid.Column="0" Spacing="4">
                <TextBlock Text="ECHIPA OPERATIONALA" Classes="label" />
                <TextBlock Text="Tehnicieni" Classes="h1" />
            </StackPanel>
            <Button Grid.Column="1" Classes="ghost" Content="↻ Refresh" Command="{Binding LoadCommand}" VerticalAlignment="Center" />
        </Grid>

        <!-- Lista tehnicieni — fiecare devine un card "trading card" cu metrici relevante -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="models:Technician">
                        <Border Width="340" Margin="0,0,16,16"
                                Classes="card"
                                Padding="22">
                            <StackPanel Spacing="14">
                                <!-- Header: cod + nivel -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding CodTehnician}"
                                               Classes="mono"
                                               FontSize="11"
                                               Foreground="{DynamicResource Accent}" />
                                    <Border Grid.Column="1" Classes="pill"
                                            Background="{DynamicResource GlassFill}"
                                            BorderBrush="{DynamicResource GlassBorderActive}"
                                            BorderThickness="1">
                                        <TextBlock Text="{Binding Nivel}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource Accent}" />
                                    </Border>
                                </Grid>

                                <StackPanel Spacing="2">
                                    <TextBlock Text="{Binding Nume}" FontSize="20" FontWeight="Bold" />
                                    <TextBlock Text="{Binding Specializare}" Classes="muted" />
                                </StackPanel>

                                <Border Height="1" Background="{DynamicResource GlassBorder}" />

                                <!-- Metrici cheie — 3 coloane -->
                                <Grid ColumnDefinitions="*,*,*">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding TicheteRezolvate}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource StatusSuccess}" />
                                        <TextBlock Text="rezolvate" Classes="muted" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding TicheteDeschise}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Accent}" />
                                        <TextBlock Text="active" Classes="muted" FontSize="10" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding TimpMediuRezolvareOre, StringFormat='{}{0:F1}h', FallbackValue='—'}"
                                                   FontSize="22" FontWeight="Bold" />
                                        <TextBlock Text="medie" Classes="muted" FontSize="10" />
                                    </StackPanel>
                                </Grid>

                                <!-- Rating cu stele Unicode — pastrat simplu, fara controale custom -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="SATISFACTIE" Classes="label" VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{Binding RatingMediu, Converter={x:Static controls:Converters.RatingToStars}}"
                                                   Foreground="{DynamicResource Accent}" FontSize="14" />
                                        <TextBlock Text="{Binding RatingMediu, StringFormat='{}{0:F1}', FallbackValue='—'}"
                                                   Classes="mono muted" FontSize="11" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
