<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ITCareHelpdesk.App.ViewModels"
        xmlns:svg="using:Avalonia.Svg.Skia"
        xmlns:controls="using:ITCareHelpdesk.App.Controls"
        x:Class="ITCareHelpdesk.App.Views.SplashWindow"
        x:DataType="vm:SplashViewModel"
        Title="ITCare Helpdesk"
        Width="640" Height="420"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        CanResize="False"
        Background="Transparent">

    <!-- Fereastra borderless cu blur de fundal pe Windows 11 — efectul "modern app launcher".
         Pe alte OS-uri pica gracefully la background-ul nostru. -->

    <Border CornerRadius="20"
            BorderThickness="1"
            BorderBrush="{DynamicResource GlassBorder}"
            Background="{DynamicResource BgDeep}"
            BoxShadow="0 32 80 0 #00000080">

        <Grid RowDefinitions="*,Auto,Auto,Auto" Margin="40">

            <!-- Particule animate pe Skia in background — adauga "viata" fara sa distraga.
                 Pus pe row 0 ca sa ocupe spatiul de sus complet. -->
            <controls:ParticleField Grid.Row="0" />

            <!-- Logo centrat — folosim Svg din Avalonia.Svg.Skia ca sa pastram vectorul curat -->
            <Viewbox Grid.Row="0" Width="280" Height="100"
                     HorizontalAlignment="Center" VerticalAlignment="Center">
                <svg:Svg Path="/Assets/logo-itcare.svg" />
            </Viewbox>

            <!-- Eticheta produs sub logo -->
            <TextBlock Grid.Row="1"
                       Text="HELPDESK &amp; ASSET MANAGEMENT"
                       Classes="label"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,32" />

            <!-- Progress bar custom — subtire, doar 2 pixeli, cyan glow -->
            <Grid Grid.Row="2" Height="2" Margin="0,0,0,16">
                <Rectangle Fill="{DynamicResource GlassBorder}" />
                <Rectangle Fill="{DynamicResource Accent}"
                           HorizontalAlignment="Left"
                           Width="{Binding Progress, Converter={x:Static controls:Converters.ProgressToWidth}, ConverterParameter=560}">
                    <Rectangle.Effect>
                        <!-- BlurEffect ca progresul sa "lumineze" — mic detaliu, dar misto pe ochii care urmaresc -->
                        <DropShadowEffect Color="#43BAFF" BlurRadius="12" OffsetX="0" OffsetY="0" />
                    </Rectangle.Effect>
                </Rectangle>
            </Grid>

            <!-- Status text -->
            <DockPanel Grid.Row="3">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Progress, StringFormat='{}{0:P0}'}"
                           Classes="mono muted"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}"
                           Classes="body"
                           Foreground="{DynamicResource TextSecondary}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <!-- Eroare suprapusa — vizibila doar daca HasError = true -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Background="{DynamicResource BgDeep}"
                    Opacity="0.97"
                    CornerRadius="20"
                    IsVisible="{Binding HasError}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Stretch" Spacing="14" Margin="32,24">
                    <TextBlock Text="!" FontSize="56" FontWeight="Black" Foreground="{DynamicResource StatusCritical}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Eroare conectare" Classes="h3" HorizontalAlignment="Center" />
                    <ScrollViewer MaxHeight="220" HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Classes="mono"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextSecondary}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Left" />
                    </ScrollViewer>
                    <Button Content="Inchide"
                            Classes="primary"
                            Click="OnCloseClick"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0" />
                </StackPanel>
            </Border>

        </Grid>
    </Border>
</Window>
